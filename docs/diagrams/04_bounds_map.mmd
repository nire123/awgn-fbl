graph TB
    Rstar(["R*(n, ε)<br/><i>true maximum rate</i>"])

    subgraph Converse["CONVERSE · upper bounds on R"]
        Ccap["Shannon capacity C<br/><i>asymptotic</i>"]
        Cnct["Cone-packing converse<br/>NoncentralTConverse · β-optimal"]
        Cchi["Relaxed χ² converse<br/>ChiSquared (scipy) · Erseghe (Temme)"]
        Csph["SolidAngle converse<br/>n ≤ 80"]
    end

    subgraph Achievable["ACHIEVABLE · lower bounds on R"]
        Arcu["RCU+<br/>avg err · ε↔R"]
        Aga["Gallager<br/>avg err · ε↔R"]
        Akb1["κβ simple<br/>max err · ε→R"]
        Akb2["κβ PPV-faithful<br/>max err · ε→R"]
    end

    subgraph Approx["APPROXIMATION"]
        Anorm["Normal approximation<br/>R ≈ C − √(V/n)Q⁻¹(ε)<br/>+ log₂(n)/(2n)"]
    end

    Ccap  -. bounds .-> Rstar
    Cnct  -. bounds .-> Rstar
    Cchi  -. bounds .-> Rstar
    Csph  -. bounds .-> Rstar
    Rstar -. bounds .-> Arcu
    Rstar -. bounds .-> Aga
    Rstar -. bounds .-> Akb1
    Rstar -. bounds .-> Akb2
    Anorm -. approx .-> Rstar

    classDef truth fill:#ffebee,stroke:#b71c1c,stroke-width:3px
    classDef conv fill:#e3f2fd,stroke:#0d47a1
    classDef ach fill:#fff3cd,stroke:#856404
    classDef approx fill:#f3e5f5,stroke:#4a148c

    class Rstar truth
    class Ccap,Cnct,Cchi,Csph conv
    class Arcu,Aga,Akb1,Akb2 ach
    class Anorm approx
