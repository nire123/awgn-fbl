graph TD
    subgraph Primitives
        cap["capacity.py<br/>C(SNR) · V(SNR)"]
        pair["_pairwise.py<br/>Lemma 1 · log NCT CDF"]
    end

    subgraph Converse
        conv["converse.py<br/>NCT · χ² · SolidAngle"]
        ers["erseghe.py<br/>Temme χ² converse"]
        na["normal_approx.py"]
    end

    subgraph Evaluator
        fast["fast_f.py<br/>FastFREvaluator: F(R) PCHIP"]
    end

    subgraph Achievability
        ach["achievable.py<br/>RCU+ · κβ ×2 · Gallager · ExactRC"]
    end

    subgraph Presentation
        plot["plot.py<br/>plot() + wrappers"]
        gen["generate_chapter_figures.py"]
    end

    pair --> conv
    cap --> na
    conv --> fast
    pair --> ach
    conv --> ach
    fast --> ach
    conv --> plot
    ers --> plot
    ach --> plot
    na --> plot
    plot --> gen

    classDef prim fill:#e2e3e5,stroke:#383d41
    classDef bound fill:#d4edda,stroke:#155724,stroke-width:2px
    classDef infra fill:#cce5ff,stroke:#004085
    class cap,pair prim
    class conv,ers,na,fast,ach bound
    class plot,gen infra
